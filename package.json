{
  "name": "portfolio-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "start": "turbo start",
    "clean": "turbo clean && rm -rf node_modules",
    "dev:next": "turbo dev --filter=next-portfolio",
    "dev:tanstack": "turbo dev --filter=tanstack-portfolio",
    "build:next": "turbo build --filter=next-portfolio",
    "build:tanstack": "turbo build --filter=tanstack-portfolio",
    "start:next": "turbo start --filter=next-portfolio",
    "start:tanstack": "turbo start --filter=tanstack-portfolio"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5"
  }
}
